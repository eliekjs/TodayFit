# Supabase (Sport Mode data layer)
# Copy to .env and fill in values from your Supabase project settings.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — required for maintenance scripts that UPDATE the DB (--apply). Not the same as the anon key.
# Get it: Dashboard → Project Settings → API → "service_role" (secret). Never commit it.
#   npm run backfill:workout-levels:apply
#   npm run sync:exercise-junctions:apply
# SUPABASE_SERVICE_ROLE_KEY=
