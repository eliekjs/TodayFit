{
  "name": "todayfit",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev": "CI=false expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "node scripts/run-ios.js",
    "ios:clear": "node scripts/run-ios.js --clear",
    "web": "expo start --web",
    "web:dev": "CI=false expo start --web",
    "web:dev:clear": "CI=false expo start --web --clear",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run lint && npm run test",
    "test:generator": "npx tsx logic/workoutGeneration/seedTest.ts",
    "test:generator-async": "npx tsx lib/generator.integration.test.ts",
    "review:generator-workouts": "npx tsx scripts/reviewGeneratorWorkouts.ts",
    "test:phase5": "npx tsx logic/workoutIntelligence/constraints/eligibility.test.ts",
    "test:prescription-evidence": "npx tsx logic/workoutGeneration/prescription-evidence.test.ts",
    "test:exercise-frequency": "npx tsx scripts/exerciseFrequencyTest.ts",
    "test:exercise-database-opportunity": "npx tsx logic/workoutGeneration/exerciseDatabaseOpportunity.test.ts",
    "test:exercise-ontology-coverage": "npx tsx logic/workoutGeneration/exerciseOntologyCoverage.test.ts",
    "audit:exercise-ontology-coverage:snapshot": "npx tsx scripts/auditExerciseTagCoverageSnapshot.ts",
    "validate:autonomous-pr": "node scripts/validate-autonomous-pr.js",
    "test:exercise-catalog-policy": "npx tsx lib/exerciseCatalogPolicy.test.ts",
    "test:sport-tailored-scoring": "npx tsx logic/workoutGeneration/sportTailoredScoring.test.ts",
    "backfill:workout-levels": "npx tsx scripts/backfillWorkoutLevels.ts",
    "backfill:workout-levels:apply": "npx tsx scripts/backfillWorkoutLevels.ts --apply",
    "sync:exercise-junctions": "npx tsx scripts/syncExerciseJunctionsFromMerged.ts",
    "sync:exercise-junctions:apply": "npx tsx scripts/syncExerciseJunctionsFromMerged.ts --apply",
    "audit:workout-levels": "npx tsx scripts/auditWorkoutLevels.ts",
    "compare:workout-tiers": "npx tsx scripts/compareWorkoutTiers.ts",
    "eval:workout-quality": "npx tsx scripts/workoutGenerationQualityEval.ts",
    "verify:sport-profile-canonical": "npx tsx scripts/verifySportProfileCanonicalization.ts",
    "audit:exercise-metadata-quality": "npx tsx scripts/exerciseMetadataQualityAgent.ts",
    "audit:exercise-library": "npx tsx scripts/exerciseLibraryCuration/auditExerciseLibrary.ts",
    "prefill:exercise-curation": "npx tsx scripts/exerciseLibraryCuration/runPrefillRules.ts",
    "curation:llm-classify": "npx tsx scripts/exerciseLibraryCuration/runLlmClassification.ts",
    "curation:cluster-duplicates": "npx tsx scripts/exerciseLibraryCuration/clusterDuplicates.ts",
    "curation:library-prune": "npx tsx scripts/exerciseLibraryCuration/runLibraryPruning.ts",
    "curation:generator-eligibility-preview": "npx tsx scripts/exerciseLibraryCuration/runGeneratorEligibilityPreview.ts",
    "curation:sync-supabase": "npx tsx scripts/exerciseLibraryCuration/syncCurationToSupabase.ts",
    "curation:verify-supabase": "npx tsx scripts/exerciseLibraryCuration/verifySupabaseCurationSync.ts",
    "test:pruning-gate": "npx tsx logic/workoutGeneration/pruningGatePool.test.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4",
    "xlsx": "^0.18.5"
  },
  "private": true
}
